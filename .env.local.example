# ============================================================
# このファイルをコピーして .env.local を作成し、各値を設定してください
# cp .env.local.example .env.local
# ============================================================

# ============================================================
# Firebase Configuration (Public - safe to expose to client)
# Firebase Console > Project Settings > Your apps > Web app
# ============================================================
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ============================================================
# Google Cloud Configuration (Server-side only)
# ローカル開発時のみ。Cloud Run では Workload Identity を使用。
# ============================================================
GOOGLE_CLOUD_PROJECT_ID=
# ローカル開発時: サービスアカウントキーのパス（Cloud Run では不要）
GOOGLE_APPLICATION_CREDENTIALS=/path/to/your-service-account.json

# ============================================================
# Firebase Admin SDK (Server-side only - NEVER expose to client)
# Firebase Console > Project Settings > Service accounts > Generate new private key
# ============================================================
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ============================================================
# Vertex AI Agent Builder
# CRITICAL: Location must be 'global', use short IDs only
# ============================================================
VERTEX_AI_LOCATION=global
VERTEX_AI_ENGINE_ID=
VERTEX_AI_DATA_STORE_ID=

# ============================================================
# Cloud Storage
# ============================================================
GCS_BUCKET_NAME=

# ============================================================
# Translation
# GCP Console で Cloud Translation API を有効化してください
# ============================================================
ENABLE_AUTO_TRANSLATE=true

# ============================================================
# Admin API 認証シークレット（本番では強いランダム値を使用）
# 生成例: openssl rand -hex 32
# ============================================================
CRON_SECRET=

# ============================================================
# Admin
# 設定ページの管理者専用セクションを表示するメールアドレス
# ============================================================
NEXT_PUBLIC_ADMIN_EMAIL=

# ============================================================
# Features
# ============================================================
ENABLE_QUERY_CACHE=true
ENABLE_AUTO_COLLECTOR=false
MAX_UPLOAD_SIZE_MB=100
MIN_CITATION_COUNT=50
